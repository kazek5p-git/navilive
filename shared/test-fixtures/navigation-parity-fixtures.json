{
  "addressCases": [
    {
      "name": "street_and_house_number_from_address_fields",
      "address": {
        "road": "Kalwaryjska",
        "house_number": "123",
        "city": "Kraków",
        "state": "Małopolskie",
        "country": "Polska"
      },
      "fallback": "123 Kalwaryjska, Kraków, Małopolskie, Polska",
      "expected": "Kalwaryjska 123, Kraków, Małopolskie"
    },
    {
      "name": "fallback_reorders_leading_house_number",
      "address": null,
      "fallback": "123 Dupowa, Dupniki, Małopolskie, Polska",
      "expected": "Dupowa 123, Dupniki, Małopolskie, Polska"
    },
    {
      "name": "short_address_appends_country",
      "address": {
        "road": "Stara",
        "house_number": "7",
        "country": "Polska"
      },
      "fallback": "7 Stara, Polska",
      "expected": "Stara 7, Polska"
    },
    {
      "name": "house_number_uses_fallback_street_context",
      "address": {
        "house_number": "45",
        "city": "Kraków",
        "state": "Małopolskie",
        "country": "Polska"
      },
      "fallback": "45 Szewska, Kraków, Małopolskie, Polska",
      "expected": "Szewska 45, Kraków, Małopolskie"
    }
  ],
